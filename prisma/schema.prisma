generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles & Permissions ────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  reseller
  support
  pending
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique // e.g. "licenses:create"
  label String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@map("role_permissions")
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String   @unique
  passwordHash String   @default("")
  role         UserRole @default(pending)
  active       Boolean  @default(false)
  // Discord OAuth fields
  discordId    String?  @unique
  discordAvatar String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet          Wallet?
  creditWallet    CreditWallet?
  licenses        License[]
  auditLogs       AuditLog[]
  telegramAccount TelegramAccount?
  providerRequests ProviderRequest[]

  @@map("users")
}

// ── Credits ────────────────────────────────────────────────────────────────────

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_wallets")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0) // stored as integer credits (no floats)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("wallets")
}

enum TransactionType {
  credit_add
  credit_remove
  license_created
  refund
  transfer_in
  transfer_out
}

model CreditTransaction {
  id          String          @id @default(cuid())
  walletId    String
  amount      Int
  type        TransactionType
  reason      String?
  createdById String?
  createdAt   DateTime        @default(now())

  wallet    Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ── Products ───────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Int      @default(0) // in credits
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  licenses         License[]
  voiceRules       VoiceRule[]
  providerProducts ProviderProduct[]
  providerRequests ProviderRequest[]

  @@map("products")
}

// ── Licenses ───────────────────────────────────────────────────────────────────

enum LicenseStatus {
  active
  inactive
  expired
  banned
}

model License {
  id         String        @id @default(cuid())
  key        String        @unique @default(cuid())
  userId     String
  productId  String
  status     LicenseStatus @default(active)
  expiresAt  DateTime?
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id])
  voiceSession VoiceSession?

  @@map("licenses")
}

// ── Discord ────────────────────────────────────────────────────────────────────

model DiscordGuild {
  id        String   @id @default(cuid())
  guildId   String   @unique
  name      String
  iconUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels DiscordChannel[]

  @@map("discord_guilds")
}

model DiscordChannel {
  id        String   @id @default(cuid())
  guildId   String
  channelId String   @unique
  name      String
  type      String   @default("voice") // voice | text | category
  active    Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())

  guild         DiscordGuild   @relation(fields: [guildId], references: [guildId])
  voiceRule     VoiceRule?
  voiceSessions VoiceSession[]
  cooldowns     VoiceCooldown[]

  @@map("discord_channels")
}

// ── Voice Rules ────────────────────────────────────────────────────────────────

model VoiceRule {
  id               String   @id @default(cuid())
  channelId        String   @unique
  productId        String
  enabled          Boolean  @default(true)
  durationMinutes  Int      @default(60)
  cooldownSeconds  Int      @default(0)
  maxPerDay        Int      @default(100)
  licensePrefix    String?  // e.g. "FF", "IOS", "VPN"
  licenseTemplate  String?  // e.g. "PREFIX-XXXX-XXXX"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])

  @@map("voice_rules")
}

// ── Voice Sessions ─────────────────────────────────────────────────────────────

model VoiceSession {
  id              String    @id @default(cuid())
  channelId       String
  discordUserId   String
  discordUsername String
  licenseId       String?   @unique
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  durationSeconds Int?

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  license License?       @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@index([discordUserId])
  @@map("voice_sessions")
}

// ── Voice Cooldowns ────────────────────────────────────────────────────────────

model VoiceCooldown {
  id            String   @id @default(cuid())
  channelId     String
  discordUserId String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, discordUserId])
  @@map("voice_cooldowns")
}

// ── Telegram ───────────────────────────────────────────────────────────────────

model TelegramAccount {
  id         String   @id @default(cuid())
  userId     String   @unique
  telegramId String   @unique
  username   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_accounts")
}

// ── Providers ─────────────────────────────────────────────────────────────────

enum ProviderType {
  telegram_bot
  telegram_user
  keyauth
  auth_panel
  rest_api
}

model Provider {
  id          String       @id @default(cuid())
  name        String
  type        ProviderType
  active      Boolean      @default(true)
  config      Json         // connection params (bot token, base url, etc.)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products       ProviderProduct[]
  accounts       ProviderAccount[]
  requests       ProviderRequest[]
  logs           ProviderLog[]
  conversations  ProviderConversation[]
  jobs           ProviderJob[]

  @@map("providers")
}

model ProviderProduct {
  id           String   @id @default(cuid())
  providerId   String
  productId    String
  externalRef  String   // identifier used by the provider (command, product id, etc.)
  metadata     Json?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([providerId, productId])
  @@map("provider_products")
}

model ProviderAccount {
  id         String   @id @default(cuid())
  providerId String
  label      String   // e.g. "bot_account_1"
  credentials Json    // bot token, api key, session string, etc. (encrypted at app level)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("provider_accounts")
}

// ── Provider Conversations & Jobs ────────────────────────────────────────────

model ProviderConversation {
  id              String   @id @default(cuid())
  providerId      String
  telegramUserId  String   // our bot's user id used to track the session
  state           String   @default("idle") // idle | waiting_response | done | error
  lastMessageId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, telegramUserId])
  @@map("provider_conversations")
}

enum JobStatus {
  pending
  running
  done
  failed
}

model ProviderJob {
  id          String    @id @default(cuid())
  providerId  String
  requestId   String
  status      JobStatus @default(pending)
  payload     Json
  response    Json?
  retries     Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  provider Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  request  ProviderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([status])
  @@map("provider_jobs")
}

// ── Provider Requests & Logs ──────────────────────────────────────────────────

enum ProviderRequestStatus {
  pending
  processing
  completed
  failed
}

model ProviderRequest {
  id           String                @id @default(cuid())
  providerId   String
  productId    String
  userId       String
  requestType  String                @default("license") // license | revoke
  status       ProviderRequestStatus @default(pending)
  responseData Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  provider Provider      @relation(fields: [providerId], references: [id])
  product  Product       @relation(fields: [productId],  references: [id])
  user     User          @relation(fields: [userId],     references: [id])
  jobs     ProviderJob[]

  @@index([providerId])
  @@index([userId])
  @@index([status])
  @@map("provider_requests")
}

model ProviderLog {
  id         String   @id @default(cuid())
  providerId String
  action     String
  request    Json?
  response   Json?
  error      String?
  createdAt  DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([createdAt])
  @@map("provider_logs")
}

// ── Integrations ───────────────────────────────────────────────────────────────

model Integration {
  id        String   @id @default(cuid())
  name      String
  type      String   // webhook | api | bot | etc.
  active    Boolean  @default(true)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

// ── Audit Logs ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ── Settings ───────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
