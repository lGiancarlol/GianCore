generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles & Permissions ────────────────────────────────────────────────────────

enum UserRole {
  owner
  admin
  reseller
  support
  pending
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique // e.g. "licenses:create"
  label String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([role, permissionId])
  @@map("role_permissions")
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String   @unique
  passwordHash String   @default("")
  role         UserRole @default(pending)
  active       Boolean  @default(false)
  // Discord OAuth fields
  discordId    String?  @unique
  discordAvatar String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet          Wallet?
  creditWallet    CreditWallet?
  licenses        License[]
  auditLogs       AuditLog[]
  telegramAccount TelegramAccount?

  @@map("users")
}

// ── Credits ────────────────────────────────────────────────────────────────────

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_wallets")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0) // stored as integer credits (no floats)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("wallets")
}

enum TransactionType {
  credit_add
  credit_remove
  license_created
  refund
  transfer_in
  transfer_out
}

model CreditTransaction {
  id          String          @id @default(cuid())
  walletId    String
  amount      Int
  type        TransactionType
  reason      String?
  createdById String?
  createdAt   DateTime        @default(now())

  wallet    Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ── Products ───────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Int      @default(0) // in credits
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  licenses   License[]
  voiceRules VoiceRule[]

  @@map("products")
}

// ── Licenses ───────────────────────────────────────────────────────────────────

enum LicenseStatus {
  active
  inactive
  expired
  banned
}

model License {
  id         String        @id @default(cuid())
  key        String        @unique @default(cuid())
  userId     String
  productId  String
  status     LicenseStatus @default(active)
  expiresAt  DateTime?
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id])
  voiceSession VoiceSession?

  @@map("licenses")
}

// ── Discord ────────────────────────────────────────────────────────────────────

model DiscordGuild {
  id        String   @id @default(cuid())
  guildId   String   @unique
  name      String
  iconUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels DiscordChannel[]

  @@map("discord_guilds")
}

model DiscordChannel {
  id        String   @id @default(cuid())
  guildId   String
  channelId String   @unique
  name      String
  type      String   @default("voice") // voice | text | category
  active    Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())

  guild         DiscordGuild   @relation(fields: [guildId], references: [guildId])
  voiceRule     VoiceRule?
  voiceSessions VoiceSession[]
  cooldowns     VoiceCooldown[]

  @@map("discord_channels")
}

// ── Voice Rules ────────────────────────────────────────────────────────────────

model VoiceRule {
  id               String   @id @default(cuid())
  channelId        String   @unique
  productId        String
  enabled          Boolean  @default(true)
  durationMinutes  Int      @default(60)
  cooldownSeconds  Int      @default(0)
  maxPerDay        Int      @default(100)
  licensePrefix    String?  // e.g. "FF", "IOS", "VPN"
  licenseTemplate  String?  // e.g. "PREFIX-XXXX-XXXX"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])

  @@map("voice_rules")
}

// ── Voice Sessions ─────────────────────────────────────────────────────────────

model VoiceSession {
  id              String    @id @default(cuid())
  channelId       String
  discordUserId   String
  discordUsername String
  licenseId       String?   @unique
  joinedAt        DateTime  @default(now())
  leftAt          DateTime?
  durationSeconds Int?

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  license License?       @relation(fields: [licenseId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@index([discordUserId])
  @@map("voice_sessions")
}

// ── Voice Cooldowns ────────────────────────────────────────────────────────────

model VoiceCooldown {
  id            String   @id @default(cuid())
  channelId     String
  discordUserId String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  channel DiscordChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, discordUserId])
  @@map("voice_cooldowns")
}

// ── Telegram ───────────────────────────────────────────────────────────────────

model TelegramAccount {
  id         String   @id @default(cuid())
  userId     String   @unique
  telegramId String   @unique
  username   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_accounts")
}

// ── Integrations ───────────────────────────────────────────────────────────────

model Integration {
  id        String   @id @default(cuid())
  name      String
  type      String   // webhook | api | bot | etc.
  active    Boolean  @default(true)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

// ── Audit Logs ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

// ── Settings ───────────────────────────────────────────────────────────────────

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
